# Project Git ignore policy
# Track source, configuration, documentation and versioned release artifacts.
# Ignore local indexes, IDE state, generated build outputs and runtime caches.

# -----------------------------------------------------------------------------
# Operating system and editor metadata
# -----------------------------------------------------------------------------
Thumbs.db
Desktop.ini
ehthumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Local analysis/index tools
# -----------------------------------------------------------------------------
.codegraph/
.codebuddy/
.metadata/
.omo/
.opencode/

# -----------------------------------------------------------------------------
# Python GUI: keep project source, ignore local environments and caches
# -----------------------------------------------------------------------------
tools/*
!tools/mspm0_configurator/
!tools/mspm0_configurator/**
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
**/.pytest_cache/
*.egg-info/
**/*.egg-info/
build/
dist/

# -----------------------------------------------------------------------------
# Keil MDK generated outputs and per-user state
# Keep .uvprojx; ignore .uvoptx/.uvguix and compiler products.
# -----------------------------------------------------------------------------
*.o
*.d
*.axf
*.map
*.htm
*.lnp
*.lst
*.crf
*.dep
*.sct
# Required linker command files are source/configuration, not build products.
!MSPM0G3507_FreeRTOS/keil/mspm0g3507.sct
!source/**/linker_files/**/*.sct
*.tra
*.iex
*.fed
*.lin
*.wrn
*.brf
*.uvoptx
*.uvprojx.bak
*.uvguix.*
*._ac
*._ia
*.__i
**/Listings/
**/listings/
**/Objects/
**/objects/
**/RTE/
MSPM0G3507_FreeRTOS/keil/FactoryTest/
MSPM0G3507_FreeRTOS/keil/JLinkLog.txt
MSPM0G3507_FreeRTOS/keil/build_log.txt

# Versioned firmware is intentionally retained only here.
!MSPM0G3507_FreeRTOS/keil/Release/
!MSPM0G3507_FreeRTOS/keil/Release/*.hex
!MSPM0G3507_FreeRTOS/keil/Release/README.md

# -----------------------------------------------------------------------------
# TI SysConfig backups and generated temporary files
# -----------------------------------------------------------------------------
*.cfg.bak

# -----------------------------------------------------------------------------
# Logs, diagnostics, coverage and temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.cache
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Archives and local backups
# -----------------------------------------------------------------------------
*.rar
*.zip
*.7z
*.tar
*.tar.gz
*.bak

# -----------------------------------------------------------------------------
# SDK/reference material not used by this application target
# -----------------------------------------------------------------------------
examples/
imports.mak
AxiomTrace-main/
release_notes_*.html
known_issues_FAQ.html
manifest_*.html
license_*.txt
mspm0sdk_*.log

# -----------------------------------------------------------------------------
# Project-local unused templates and generated documentation
# -----------------------------------------------------------------------------
MSPM0G3507_FreeRTOS/Event.dot
MSPM0G3507_FreeRTOS/README.html
MSPM0G3507_FreeRTOS/BSP/Peripherals/_bsp_template.c
MSPM0G3507_FreeRTOS/BSP/Peripherals/_bsp_template.h
MSPM0G3507_FreeRTOS/BSP/HAL/_hal_template.c
MSPM0G3507_FreeRTOS/keil/EventRecorderStub.scvd
