# ============================================================
# AxiomTrace .gitignore
# ============================================================

# --- Build output ---
build/
build_*/
Testing/
bin/
obj/

# --- C compiled artifacts ---
*.o
*.a
*.so
*.lib
*.dll
*.obj
*.d

# --- Embedded firmware artifacts ---
*.elf
*.bin
*.hex
*.map
*.uf2

# Versioned binary protocol fixtures used by golden-vector validation
!tool/golden/frames/*.bin

# --- CMake ---
CMakeCache.txt
CMakeFiles/
cmake-build-*/
compile_commands.json
.cmake/

# --- Coverage ---
*.gcov
*.gcda
*.gcno
htmlcov/
.coverage
coverage/

# --- Python artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
*.egg
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pylint.d/

# --- Python virtual environments ---
venv/
.venv/
env/
.env

# --- IDE and editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.sublime-project
*.sublime-workspace
*.code-workspace

# --- clangd / ccls ---
.cache/clangd/
.ccls-cache/
.ccls

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- AI / development tools ---
.sisyphus/

# --- Archives ---
*.tar.gz
*.zip
*.rar

# --- Node.js (if tool/ subproject uses it) ---
node_modules/

# --- Project specific generated files ---
axiomtrace_amalgamated.h

# --- Test reports and benchmark data ---
test_report/
test_report*.md
performance_report*.md
perf_report*.md

# --- Test binaries (not golden test data) ---
*.exe

# --- Tool / Python build artifacts ---
tool/dist/
tool/*.egg-info/
tool/src/*.egg-info/

# --- Build baselines ---
build_baseline/

# --- CTest output ---
Testing/Temporary/
Testing/Temporary/***
